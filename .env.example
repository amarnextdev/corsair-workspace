# Copy to .env and fill in values.

# Supabase Postgres — pooler URL for the Next.js app (port 6543)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase Postgres — direct URL for Drizzle migrations (port 5432)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres"

# Auth — generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-at-least-32-characters-long"

# SMTP (Gmail example — use an App Password, not your normal Gmail password)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@gmail.com"
SMTP_PASS="your-16-char-app-password"
EMAIL_FROM="Corsair Workspace <your@gmail.com>"
# EMAIL_FROM alias (either works):
# SMTP_FROM="Corsair Workspace <your@gmail.com>"

# Google OAuth (Gmail + Calendar) — one OAuth client for the app
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APP_URL="http://localhost:3000"
OAUTH_REDIRECT_URI="http://localhost:3000/api/oauth/callback"

# Gmail push webhooks — full Pub/Sub topic name (required for live Gmail sync)
# Example: projects/my-gcp-project/topics/corsair-gmail
# Create a push subscription on this topic → POST {APP_URL}/api/webhooks
GMAIL_PUBSUB_TOPIC=""

# Corsair
CORSAIR_KEK="your-base64-encryption-key"
TENANT_ID="dev"

# Agent — chat + tools (Groq recommended for dev; OpenAI/Anthropic better for tool loops)
GROQ_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_GENERATIVE_AI_API_KEY=""

# Mem0 long-term user memory (https://app.mem0.ai)
# Set MEM0_ENABLED=true and provide MEM0_API_KEY to enable
MEM0_ENABLED=false
MEM0_API_KEY=""

# Internal auth for /api/mcp (generate: openssl rand -base64 24)
AGENT_MCP_INTERNAL_SECRET=""

# Cron jobs — protect /api/cron/* routes (generate: openssl rand -base64 24)
CRON_SECRET=""
